# MongoDB Connection (for Netlify Functions)
REACT_APP_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mydatabase

# Frontend variables (Vite uses VITE_ prefix)
VITE_API_URL=/.netlify/functions

# Piovra orchestrator proxy (client-side path; proxy runs server-side)
VITE_PIOVRA_PROXY_URL=/api/piovra

# Piovra server-side config (Netlify env vars — NEVER expose as VITE_)
PIOVRA_URL=https://piovra.your-domain.com
PIOVRA_API_KEY=change-me

# Node Environment
NODE_ENV=development
